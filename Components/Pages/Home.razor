@page "/"
@using EventPulse.Data
@using EventPulse.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@rendermode InteractiveServer

<PageTitle>Dashboard - EventPulse</PageTitle>

<div class="ep-page-header">
    <h2 class="ep-page-title">Dashboard</h2>
    <p class="ep-page-subtitle">Overview of all events and registrations</p>
</div>

@if (loading)
{
    <div class="ep-spinner">
        <div class="ep-spinner-circle"></div>
        <span>Loading dashboard...</span>
    </div>
}
else
{
    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="ep-stat-card">
                <div class="ep-stat-icon indigo"><i class="bi bi-calendar-event-fill"></i></div>
                <div>
                    <div class="ep-stat-value">@totalEvents</div>
                    <div class="ep-stat-label">Total Events</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="ep-stat-card">
                <div class="ep-stat-icon purple"><i class="bi bi-clock-fill"></i></div>
                <div>
                    <div class="ep-stat-value">@upcomingEvents</div>
                    <div class="ep-stat-label">Upcoming</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="ep-stat-card">
                <div class="ep-stat-icon green"><i class="bi bi-person-check-fill"></i></div>
                <div>
                    <div class="ep-stat-value">@confirmedSeats</div>
                    <div class="ep-stat-label">Confirmed Seats</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="ep-stat-card">
                <div class="ep-stat-icon amber"><i class="bi bi-hourglass-split"></i></div>
                <div>
                    <div class="ep-stat-value">@waitlistedCount</div>
                    <div class="ep-stat-label">On Waitlist</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Upcoming Events List -->
    <div class="ep-card">
        <div class="ep-card-header">
            <h3 class="ep-card-title">Upcoming Events</h3>
            <NavLink href="events" class="btn-ep-outline">
                <i class="bi bi-arrow-right"></i> View All
            </NavLink>
        </div>
        <div class="ep-card-body">
            @if (!events.Any())
            {
                <p class="text-muted mb-0">No events yet.</p>
            }
            else
            {
                <table class="ep-table">
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Date</th>
                            <th>Capacity</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ev in events.OrderBy(e => e.Date).Take(5))
                        {
                            var confirmed = ev.Rsvps.Count(r => !r.IsWaitlisted);
                            var isFull = confirmed >= ev.MaxCapacity;
                            <tr>
                                <td class="fw-600">@ev.Title</td>
                                <td>@ev.Date.ToString("MMM dd, yyyy")</td>
                                <td>@confirmed / @ev.MaxCapacity</td>
                                <td>
                                    @if (isFull)
                                    {
                                        <span class="ep-badge ep-badge-full"><i class="bi bi-x-circle"></i> Full</span>
                                    }
                                    else
                                    {
                                        <span class="ep-badge ep-badge-open"><i class="bi bi-check-circle"></i> Open</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private bool loading = true;
    private List<Event> events = new();
    private int totalEvents;
    private int upcomingEvents;
    private int confirmedSeats;
    private int waitlistedCount;

    protected override async Task OnInitializedAsync()
    {
        events = await Db.Events
            .Include(e => e.Rsvps)
            .AsNoTracking()
            .ToListAsync();

        totalEvents = events.Count;
        upcomingEvents = events.Count(e => e.Date >= DateTime.UtcNow);
        confirmedSeats = events.Sum(e => e.Rsvps.Count(r => !r.IsWaitlisted));
        waitlistedCount = events.Sum(e => e.Rsvps.Count(r => r.IsWaitlisted));

        loading = false;
    }
}